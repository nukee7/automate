pipeline {

  agent any

  tools {
    nodejs "node-20"
  }

  stages {

    stage('Checkout') {
      steps {
        git 'https://github.com/nukee7/automate.git'
      }
    }

    stage('Install Dependencies') {
      steps {
        sh 'npm install'
      }
    }

    stage('Type Check') {
      steps {
        sh 'npm run typecheck'
      }
    }

    stage('Build Project') {
      steps {
        sh 'npm run build'
      }
    }

    stage('Build Docker Image') {
      steps {
        sh 'docker build -t taskpilot-backend .'
      }
    }

    stage('Start Containers') {
      steps {
        sh 'docker compose up -d --build'
      }
    }

  }

}